# Port the HTTP + WebSocket server binds to. In Docker this is the internal
# container port; docker-compose.yml maps it to the host.
PORT=3001

# Absolute path to the SQLite file. In Docker this is inside the /app/data
# volume; on the host it maps to ./data/poker.db.
DB_PATH=/app/data/poker.db

# Comma-separated origins allowed to upgrade the WebSocket. The browser sends
# an Origin header on the Upgrade request; anything not in this list is
# rejected with 403. Leave empty to allow all (dev only).
ORIGIN_ALLOWED=https://iamjacke.com,http://localhost:1313,http://localhost:8765

# How long a challenge nonce is valid before the client must re-request one.
AUTH_NONCE_TTL_MS=30000

# How long a disconnected player keeps their seat in a room before it's
# garbage-collected. 5 minutes is forgiving for casual play.
ROOM_GRACE_MS=300000

# Structured logging level — one of trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# Optional SMTP config for the magic-link email flow. If SMTP_HOST is empty
# the server falls back to logging the 6-digit code to stdout (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@iamjacke.com
